# .env.production.example
# Copy to .env.production on the EC2 instance and fill in real values.
# NEVER commit .env.production to Git.

# ── PostgreSQL ─────────────────────────────────────────────────
POSTGRES_DB=studyplanner
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Spring Boot / JWT ──────────────────────────────────────────
APP_JWT_SECRET=CHANGE_ME_base64_encoded_secret_min_32_chars
APP_JWT_EXPIRATION=86400000

# ── ECR image coordinates (set by CI or manually) ─────────────
# These are exported by the deploy script; you may also hardcode them here.
# ECR_BACKEND=<account>.dkr.ecr.<region>.amazonaws.com/studyplanner-backend
# ECR_FRONTEND=<account>.dkr.ecr.<region>.amazonaws.com/studyplanner-frontend
# IMAGE_TAG=latest
