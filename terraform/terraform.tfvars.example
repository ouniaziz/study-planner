# terraform.tfvars.example
# Copy this to terraform.tfvars and fill in real values.
# NEVER commit terraform.tfvars to Git.

aws_region     = "us-east-1"
project_name   = "studyplanner"
instance_type  = "t2.micro"
aws_account_id = "123456789012"   # ← replace with your 12-digit AWS account ID

# Paste the full content of your ~/.ssh/id_rsa.pub (or equivalent) here.
ssh_public_key = "ssh-rsa AAAA...your-public-key... user@host"
